*.cover
.hypothesis/

# --- Environment & local secrets (keep *.example files in git) ---
.env
.env.local
.env.*.local
!.env.example
!.env.*.example
*.secrets
secrets.yaml
secrets.yml

# --- Snowflake (key-pair auth, sessions, local CLI) ---
*.p8
rsa_key.*
snowflake_rsa_key.*
*_rsa_key.pem
snowflake_credentials.*
.snowsql/
snowsql_rt.log

# --- AWS (typical local credential locations / exports) ---
.aws/
aws-credentials.env
aws-exports.js
amplifyconfiguration.json

# --- Astronomer / Astro ---
# Keep `.astro/config.yaml` in git so `astro deploy` works from repo root.
astro_deploy_token.txt
.airflowignore.local

# --- Airflow local state (logs may contain connection errors with hints of secrets) ---
airflow_home/
airflow.cfg
standalone_admin_password.txt
webserver_config.py
airflow/logs/*
!airflow/logs/.gitkeep
config/*
!config/.gitkeep

# --- Generic key material often copied into a repo by mistake ---
id_rsa
id_rsa.pub
*.pem
*.pfx
*.p12

# --- IDE / OS ---
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- Local data downloads (PeMS exports are large; never commit) ---
data/

# --- Airflow runtime logs at repo root (from local docker-compose) ---
logs/

# --- Claude Code session metadata ---
.claude/

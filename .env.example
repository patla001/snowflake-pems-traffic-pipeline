# Used by docker compose for volume permissions (see https://airflow.apache.org/docs/apache-airflow/stable/howto/docker-compose/index.html#setting-the-right-airflow-user)
# On Linux, set to your uid:  echo "AIRFLOW_UID=$(id -u)" > .env
AIRFLOW_UID=50000

# --- Snowflake → Airflow connection (local only; never commit real secrets) ---
# Copy this file to ".env" (gitignored). docker-compose passes .env into Airflow containers.
# Astro CLI: "astro dev" also loads .env from the project root.
#
# Airflow creates connection "snowflake_default" from this env var (CONN_ID uppercased, hyphens → underscores):
# https://airflow.apache.org/docs/apache-airflow/stable/howto/connection.html#storing-connections-in-environment-variables
#
# Example URI (replace user, password, account, warehouse, role, database).
# If your username contains '@' (e.g. email login), URL-encode it as '%40'.
# Account ID is in your Snowsight URL: https://app.snowflake.com/<ORG>/<ACCOUNT>/ → use "<ORG>-<ACCOUNT>".
# AIRFLOW_CONN_SNOWFLAKE_DEFAULT=snowflake://MYUSER:MYPASSWORD@/?account=xy12345-ab67890&warehouse=TRAFFIC_PEMS_WH&database=TRAFFIC_PEMS_DB&role=ACCOUNTADMIN
#
# Or use the Airflow UI instead: Admin → Connections → Id "snowflake_default" (see docs/PIPELINE_EXECUTION.md).
# On Astronomer Cloud, set the same variable (or use Astro Secrets) in the deployment environment — do not commit .env.
